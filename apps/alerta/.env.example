# URLs de búsquedas de Idealista separadas por coma.
IDEALISTA_SEARCH_URLS=

# Filtros globales del MVP
MAX_PRICE=
MIN_ROOMS=
MIN_AREA=
REQUIRED_KEYWORDS=
BLOCKED_KEYWORDS=

# Ejecución
DRY_RUN=true
MAX_RESULTS_PER_RUN=10
RUN_MODE=once
POLL_INTERVAL_SECONDS=300
RETRY_COUNT=2
RETRY_BASE_DELAY_MS=400
HTTP_TIMEOUT_MS=15000

# Persistencia local (opcional). Si no se define, usa:
# <repo>/apps/alerta/.state/seen-listings.json
# STATE_FILE=/ruta/absoluta/seen-listings.json

# Notificaciones (Telegram es el canal principal del MVP)
ENABLE_TELEGRAM=true
ENABLE_WHATSAPP=false

# Telegram Bot API
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WhatsApp via Twilio API (opcional / fase posterior)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+34XXXXXXXXX
