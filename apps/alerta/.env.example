# URLs de búsquedas de Idealista separadas por coma.
# Ejemplo: https://www.idealista.com/alquiler-viviendas/madrid-madrid/,https://www.idealista.com/venta-viviendas/barcelona-barcelona/
IDEALISTA_SEARCH_URLS=

# Filtros globales del MVP
MAX_PRICE=
MIN_ROOMS=
MIN_AREA=
REQUIRED_KEYWORDS=
BLOCKED_KEYWORDS=

# Persistencia local
STATE_FILE=apps/alerta/.state/seen-listings.json

# Notificaciones
ENABLE_TELEGRAM=true
ENABLE_WHATSAPP=false

# Telegram Bot API
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WhatsApp via Twilio API
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+34XXXXXXXXX
